    "entries": [
        {
            "speaker": "조단",
            "text": "안녕하세요! 제 이름은 조단입니다. 만나서 반가워요.",
            "note": "",
            "tags": []
        },
        {
            "speaker": "민지",
            "text": "안녕하세요 조단 씨! 저는 민지예요. 저도 만나서 반가워요.",
            "note": "",
            "tags": []
        },
        {
            "speaker": "조단",
            "text": "학생이세요?",
            "note": "",
            "tags": []
        },
        {
            "speaker": "민지",
            "text": "아니요, 저는 회사원이에요. 조단 씨는요?",
            "note": "",
            "tags": []
        },
        {
            "speaker": "조단",
            "text": "저는 대학생이에요. 한국어를 공부하고 있어요.",
            "note": "",
            "tags": []
        },
        {
            "speaker": "민지",
            "text": "와, 대단하네요! 한국어는 좀 어렵지 않나요?",
            "note": "",
            "tags": []
        },
        {
            "speaker": "조단",
            "text": "네, 어렵지만 재미있어요. 많이 도와주세요.",
            "note": "",
            "tags": []
        },
        {
            "speaker": "민지",
            "text": "물론이죠! 우리 같이 열심히 공부해요.",
            "note": "",
            "tags": []
        },
        {
            "speaker": "조단",
            "text": "감사합니다. 다음에 또 봐요!",
            "note": "",
            "tags": []
        },
        {
            "speaker": "민지",
            "text": "안녕히 가세요!",
            "note": "",
            "tags": []
        }
    ]
