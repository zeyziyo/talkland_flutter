        {
            "speaker": "ジョダン",
            "text": "こんにちは！ジョダンと言います。お会いできて嬉しいです。",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ミンジ",
            "text": "こんにちはジョダンさん！私はミンジです。私もお会いできて嬉しいです。",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ジョダン",
            "text": "学生ですか？",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ミンジ",
            "text": "いいえ、会社員です。ジョダンさんは？",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ジョダン",
            "text": "私は大学生です。韓国語を勉強しています。",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ミンジ",
            "text": "わあ、すごいですね！韓国語は少し難しいですよね？",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ジョダン",
            "text": "はい、難しいですが楽しいです。たくさん助けてください。",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ミンジ",
            "text": "もちろんです！一緒に一生懸命勉強しましょう。",
            "note": "",
            "tags": []
        },
        {
            "speaker": "ジョダン",
            "text": "ありがとうございます。また会いましょう！",
            "note": "",
            "tags": []
